{
  "name": "@hellojohn/vue",
  "version": "1.0.0",
  "description": "HelloJohn authentication SDK for Vue 3 and Nuxt 3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt/module.js",
      "require": "./dist/nuxt/module.cjs",
      "types": "./dist/nuxt/module.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dropDatabas3/hellojohn",
    "directory": "sdks/vue"
  },
  "scripts": {
    "build": "vite build",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "nuxt": {
      "optional": true
    }
  },
  "dependencies": {
    "@hellojohn/js": "file:../js"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^3.9.1",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
